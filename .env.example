# Banco local usado pelo Prisma
DATABASE_URL="file:./dev.db"

# Rede padrao do app: local ou sepolia
NEXT_PUBLIC_NETWORK=local

# RPC local do Hardhat para leituras server-side e integracao Web3
HARDHAT_RPC_URL=http://127.0.0.1:8545

# Para usar Sepolia, substitua por uma RPC valida da sua conta ou por uma RPC publica confiavel
SEPOLIA_RPC_URL=https://sua-url-sepolia

